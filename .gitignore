# Editors / IDEs
.idea
*.iml

# Stray root-level Rust build output. The rust/ reference snapshot and its root
# workspace were removed at v0.1.0; the compat harness crates ignore their own
# target/ via compat/rust-harness*/.gitignore. This stays as a safety net.
/target

# Go build / test artifacts
*.test
*.out
coverage.txt

# Local agent config
.claude/

# Patch / merge debris
*.orig
*.rej

# Editor backup / lock files
*~
\#*\#
.\#*

# OS noise
.DS_Store

__pycache__
