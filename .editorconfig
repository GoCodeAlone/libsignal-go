root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
max_line_length = 120
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4

[*.proto]
max_line_length = 80

[{*.markdown,*.md}]
indent_size = 4

# rust/ retained as upstream reference until v0.1.0
[*.rs]
indent_size = 4

[*.toml]
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4
